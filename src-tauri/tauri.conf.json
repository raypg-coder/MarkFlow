{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkFlow",
  "version": "0.1.9",
  "identifier": "com.markflow.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MarkFlow",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "极客向 Markdown 编辑器",
    "longDescription": "MarkFlow — 赛博朋克风格的 Markdown 编辑器 + 本地 LLM 集成 + 知识图谱。",
    "macOS": {
      "signingIdentity": "Developer ID Application: HOULEI PENG (E5WXP9EA8P)",
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/raypg-coder/MarkFlow/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVEQThFQzkyRUU0NjExQ0UKUldUT0VVYnVrdXlvWFpWOHZhZThTU096SVp6NWY1U0J6SnZYalhkS3FtS2hYczMxMVVyZHd5dGEK",
      "dialog": false
    }
  }
}
