# Apple Developer ID signing + notarization credentials.
# Copy this file to `.env.signing` (gitignored) and fill in real values.
# The build script (`scripts/build-signed-dmg.sh`) sources it.

# ─── Apple Developer certificate ───────────────────────────
APPLE_P12_PATH="$HOME/.apple-certs/your-developer-id.p12"
APPLE_P12_PASSWORD=""

# ─── Code signing identity (full name from Keychain) ──────
# Example: "Developer ID Application: Your Name (TEAMID12345)"
APPLE_SIGNING_IDENTITY=""

# ─── Notarization credentials ─────────────────────────────
APPLE_ID=""                  # your developer.apple.com email
APPLE_PASSWORD=""            # app-specific password (xxxx-xxxx-xxxx-xxxx)
APPLE_TEAM_ID=""             # 10-char Team ID

# ─── Tauri updater signing key (minisign) ────────────────
# Generate with: npx tauri signer generate -w ~/.tauri/markflow-updater.key
# Then put the corresponding .pub value into tauri.conf.json#plugins.updater.pubkey
TAURI_SIGNING_PRIVATE_KEY="$HOME/.tauri/markflow-updater.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
